# Anthropic API key — required. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Comma-separated list of allowed frontend origins (CORS).
# Local dev default is http://localhost:3000; in production set this to your
# deployed frontend URL, e.g. https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:3000
